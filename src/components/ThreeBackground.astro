---
// Three.js 3D Background with Dynamic Particle Twinkle & Breathing Glow
---

<div id="three-container" class="three-container"></div>

<style>
  .three-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
  }
</style>

<script>
  import * as THREE from 'three';

  let scene: THREE.Scene | null = null;
  let camera: THREE.PerspectiveCamera | null = null;
  let renderer: THREE.WebGLRenderer | null = null;
  let particlesMesh: THREE.Points | null = null;
  let torus: THREE.Mesh | null = null;
  let torus2: THREE.Mesh | null = null;
  let mouseX = 0;
  let mouseY = 0;
  let animationId: number | null = null;
  let time = 0;

  // 呼吸与闪烁参数数组
  let phaseArray: Float32Array | null = null;
  let speedArray: Float32Array | null = null;
  let baseColorArray: Float32Array | null = null;
  const particlesCount = 5000;

  function handleMouseMove(event: MouseEvent) {
    mouseX = (event.clientX / window.innerWidth) * 2 - 1;
    mouseY = -(event.clientY / window.innerHeight) * 2 + 1;
  }

  function handleResize() {
    if (!camera || !renderer) return;

    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();

    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(window.devicePixelRatio);
  }

  function initThreeAnimation() {
    const container = document.getElementById('three-container');
    if (!container) return;

    // 清理可能已存在的动画
    cleanupThreeAnimation();

    // シーンの作成
    scene = new THREE.Scene();

    // カメラの作成
    camera = new THREE.PerspectiveCamera(
      75,
      window.innerWidth / window.innerHeight,
      0.1,
      1000
    );

    // レンダラーの作成
    renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(window.devicePixelRatio);
    container.appendChild(renderer.domElement);

    camera.position.z = 5;

    // パーティクルシステムの作成
    const particlesGeometry = new THREE.BufferGeometry();
    const posArray = new Float32Array(particlesCount * 3);
    const colorArray = new Float32Array(particlesCount * 3);

    baseColorArray = new Float32Array(particlesCount * 3);
    phaseArray = new Float32Array(particlesCount);
    speedArray = new Float32Array(particlesCount);

    const getThemeColors = (themeName: string) => {
      if (themeName === 'cyberpunk') {
        return [[0.06, 0.72, 0.50], [0.02, 0.71, 0.83], [0.96, 0.62, 0.04]];
      } else if (themeName === 'aurora') {
        return [[0.66, 0.33, 0.97], [0.22, 0.74, 0.97], [0.95, 0.25, 0.37]];
      } else if (themeName === 'amber') {
        return [[0.96, 0.62, 0.04], [0.98, 0.57, 0.23], [0.52, 0.82, 0.12]];
      }
      return [[0.66, 0.33, 0.97], [0.93, 0.28, 0.60], [0.23, 0.51, 0.96]];
    };

    const initialTheme = localStorage.getItem('darkness_theme_preset') || 'default';
    const palette = getThemeColors(initialTheme);

    for (let i = 0; i < particlesCount; i++) {
      const i3 = i * 3;
      posArray[i3] = (Math.random() - 0.5) * 100;
      posArray[i3 + 1] = (Math.random() - 0.5) * 100;
      posArray[i3 + 2] = (Math.random() - 0.5) * 100;

      const pick = palette[Math.floor(Math.random() * palette.length)];
      baseColorArray[i3] = pick[0];
      baseColorArray[i3 + 1] = pick[1];
      baseColorArray[i3 + 2] = pick[2];

      colorArray[i3] = pick[0];
      colorArray[i3 + 1] = pick[1];
      colorArray[i3 + 2] = pick[2];

      // 随机相位 (0 ~ 2*PI)
      phaseArray[i] = Math.random() * Math.PI * 2;
      // 15% 快速闪烁脉冲星，85% 舒缓长调呼吸
      speedArray[i] = Math.random() < 0.15 ? 2.5 + Math.random() * 3.5 : 0.6 + Math.random() * 1.4;
    }

    particlesGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
    particlesGeometry.setAttribute('color', new THREE.BufferAttribute(colorArray, 3));

    // 主题切换事件处理
    const handleThemeChange = (e: Event) => {
      const customEvent = e as CustomEvent;
      const themeVal = customEvent.detail;
      if (!particlesMesh || !baseColorArray) return;
      const newPalette = getThemeColors(themeVal);
      for (let i = 0; i < particlesCount; i++) {
        const i3 = i * 3;
        const pick = newPalette[Math.floor(Math.random() * newPalette.length)];
        baseColorArray[i3] = pick[0];
        baseColorArray[i3 + 1] = pick[1];
        baseColorArray[i3 + 2] = pick[2];
      }
    };

    window.addEventListener('theme-change', handleThemeChange);

    // 圆形真实光晕纹理动态生成器
    const createCircleGlowTexture = () => {
      const canvas = document.createElement('canvas');
      canvas.width = 64;
      canvas.height = 64;
      const ctx = canvas.getContext('2d');
      if (!ctx) return null;

      const gradient = ctx.createRadialGradient(32, 32, 0, 32, 32, 32);
      gradient.addColorStop(0, 'rgba(255, 255, 255, 1)');       // 强发光核心
      gradient.addColorStop(0.2, 'rgba(255, 255, 255, 0.85)');   // 柔和白光内层
      gradient.addColorStop(0.5, 'rgba(255, 255, 255, 0.35)');   // 羽化渐变光晕
      gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');        // 边缘完全透明

      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, 64, 64);

      const texture = new THREE.CanvasTexture(canvas);
      texture.needsUpdate = true;
      return texture;
    };

    const particleTexture = createCircleGlowTexture();

    // パーティクル用マテリアル (圆形真实光晕粒子)
    const particlesMaterial = new THREE.PointsMaterial({
      size: 0.45,
      map: particleTexture || undefined,
      vertexColors: true,
      transparent: true,
      opacity: 0.85,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });

    particlesMesh = new THREE.Points(particlesGeometry, particlesMaterial);
    scene.add(particlesMesh);

    // 回転するトーラス（ドーナツ型）の追加
    const torusGeometry = new THREE.TorusGeometry(10, 3, 16, 100);
    const torusMaterial = new THREE.MeshBasicMaterial({
      color: 0xa855f7,
      wireframe: true,
      transparent: true,
      opacity: 0.3,
    });
    torus = new THREE.Mesh(torusGeometry, torusMaterial);
    scene.add(torus);

    // 2つ目のトーラス
    const torus2Geometry = new THREE.TorusGeometry(15, 2, 16, 100);
    const torus2Material = new THREE.MeshBasicMaterial({
      color: 0xec4899,
      wireframe: true,
      transparent: true,
      opacity: 0.2,
    });
    torus2 = new THREE.Mesh(torus2Geometry, torus2Material);
    torus2.rotation.x = Math.PI / 4;
    scene.add(torus2);

    // イベントリスナーの追加
    document.addEventListener('mousemove', handleMouseMove);
    window.addEventListener('resize', handleResize);

    // アニメーションループの開始
    time = 0;
    animate();
  }

  // アニメーションループ (含 3D 粒子动态闪烁与呼吸效果)
  function animate() {
    if (!scene || !camera || !renderer || !particlesMesh || !torus || !torus2) return;

    animationId = requestAnimationFrame(animate);
    time += 0.003;

    // 3D 粒子明暗呼吸闪烁控制
    if (particlesMesh && baseColorArray && phaseArray && speedArray) {
      const cols = particlesMesh.geometry.attributes.color.array as Float32Array;
      for (let i = 0; i < particlesCount; i++) {
        const i3 = i * 3;
        const p = phaseArray[i];
        const s = speedArray[i];

        // 柔和正弦波呼吸因子 (亮暗区间 0.2 ~ 1.3)
        const breath = 0.2 + 1.1 * (Math.sin(time * 3.0 * s + p) * 0.5 + 0.5);

        cols[i3] = baseColorArray[i3] * breath;
        cols[i3 + 1] = baseColorArray[i3 + 1] * breath;
        cols[i3 + 2] = baseColorArray[i3 + 2] * breath;
      }
      particlesMesh.geometry.attributes.color.needsUpdate = true;
    }

    // パーティクルの回転とうねり
    particlesMesh.rotation.y = time * 0.1;
    particlesMesh.rotation.x = Math.sin(time * 0.3) * 0.05;

    // トーラスの回転
    torus.rotation.x += 0.01;
    torus.rotation.y += 0.005;
    torus.rotation.z += 0.003;

    torus2.rotation.x += 0.005;
    torus2.rotation.y += 0.01;
    torus2.rotation.z += 0.002;

    // マウス追従
    camera.position.x = mouseX * 2;
    camera.position.y = mouseY * 2;
    camera.lookAt(scene.position);

    renderer.render(scene, camera);
  }

  // クリーンアップ
  function cleanupThreeAnimation() {
    if (animationId !== null) {
      cancelAnimationFrame(animationId);
      animationId = null;
    }

    document.removeEventListener('mousemove', handleMouseMove);
    window.removeEventListener('resize', handleResize);

    if (particlesMesh) {
      if (particlesMesh.material.map) {
        particlesMesh.material.map.dispose();
      }
      particlesMesh.geometry.dispose();
      particlesMesh.material.dispose();
      particlesMesh = null;
    }

    if (torus) {
      torus.geometry.dispose();
      torus.material.dispose();
      torus = null;
    }

    if (torus2) {
      torus2.geometry.dispose();
      torus2.material.dispose();
      torus2 = null;
    }

    if (renderer) {
      renderer.dispose();
      renderer = null;
    }

    scene = null;
    camera = null;
  }

  document.addEventListener('astro:page-load', () => {
    initThreeAnimation();
  });
</script>
