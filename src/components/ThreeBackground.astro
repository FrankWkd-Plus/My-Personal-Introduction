---
// Three.js による3D背景アニメーション
---

<canvas id="three-canvas"></canvas>

<script>
  import * as THREE from 'three';

  // Three.js アニメーションの初期化と管理
  let scene: THREE.Scene | null = null;
  let camera: THREE.PerspectiveCamera | null = null;
  let renderer: THREE.WebGLRenderer | null = null;
  let particlesMesh: THREE.Points<THREE.BufferGeometry, THREE.PointsMaterial> | null = null;
  let torus: THREE.Mesh<THREE.TorusGeometry, THREE.MeshBasicMaterial> | null = null;
  let torus2: THREE.Mesh<THREE.TorusGeometry, THREE.MeshBasicMaterial> | null = null;
  let asteroidRing: THREE.Points<THREE.BufferGeometry, THREE.PointsMaterial> | null = null;
  let animationId: number | null = null;
  let mouseX = 0;
  let mouseY = 0;
  let time = 0;

  // マウスムーブハンドラー
  const handleMouseMove = (event: MouseEvent) => {
    mouseX = (event.clientX / window.innerWidth) * 2 - 1;
    mouseY = -(event.clientY / window.innerHeight) * 2 + 1;
  };

  // リサイズハンドラー
  const handleResize = () => {
    if (!camera || !renderer) return;
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  };

  // Three.jsアニメーションの初期化
  function initThreeAnimation() {
    const canvas = document.getElementById('three-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    // 既存のアニメーションをクリーンアップ
    cleanupThreeAnimation();

    // シーン、カメラ、レンダラーの設定
    scene = new THREE.Scene();
    camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });

    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(window.devicePixelRatio);
    camera.position.z = 5;

    // パーティクルシステムの作成（球体散射算法：保持粒子舒展通透，不靠拢贴近）
    const particlesGeometry = new THREE.BufferGeometry();
    const particlesCount = 6000;
    const posArray = new Float32Array(particlesCount * 3);
    const colorArray = new Float32Array(particlesCount * 3);

    for (let i = 0; i < particlesCount; i++) {
      const idx = i * 3;
      // 随机半径范围 15~90，保持中间留白与广阔散落，粒子离得不贴近
      const radius = 15 + Math.random() * 75;
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos((Math.random() * 2) - 1);

      posArray[idx] = radius * Math.sin(phi) * Math.cos(theta);
      posArray[idx + 1] = radius * Math.sin(phi) * Math.sin(theta);
      posArray[idx + 2] = radius * Math.cos(phi);

      // 炫彩粒子颜色（电光紫、炫彩粉、极光青）
      const colorType = Math.random();
      if (colorType < 0.35) {
        // 霓虹紫
        colorArray[idx] = 0.66;
        colorArray[idx + 1] = 0.33;
        colorArray[idx + 2] = 0.97;
      } else if (colorType < 0.70) {
        // 电光青
        colorArray[idx] = 0.02;
        colorArray[idx + 1] = 0.71;
        colorArray[idx + 2] = 0.83;
      } else {
        // 炫光粉
        colorArray[idx] = 0.93;
        colorArray[idx + 1] = 0.28;
        colorArray[idx + 2] = 0.60;
      }
    }

    particlesGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
    particlesGeometry.setAttribute('color', new THREE.BufferAttribute(colorArray, 3));

    // 创建圆形发光粒子纹理
    function createCircleTexture(): THREE.CanvasTexture {
      const canvas = document.createElement('canvas');
      canvas.width = 64;
      canvas.height = 64;
      const ctx = canvas.getContext('2d');
      if (ctx) {
        const gradient = ctx.createRadialGradient(32, 32, 0, 32, 32, 32);
        gradient.addColorStop(0, 'rgba(255, 255, 255, 1)');
        gradient.addColorStop(0.25, 'rgba(255, 255, 255, 0.85)');
        gradient.addColorStop(0.5, 'rgba(255, 255, 255, 0.2)');
        gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');

        ctx.fillStyle = gradient;
        ctx.beginPath();
        ctx.arc(32, 32, 32, 0, Math.PI * 2);
        ctx.fill();
      }

      const texture = new THREE.CanvasTexture(canvas);
      texture.needsUpdate = true;
      return texture;
    }

    const circleTexture = createCircleTexture();

    // パーティクル用マテリアル
    const particlesMaterial = new THREE.PointsMaterial({
      size: 0.26,
      map: circleTexture,
      vertexColors: true,
      transparent: true,
      opacity: 0.8,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
    });

    particlesMesh = new THREE.Points(particlesGeometry, particlesMaterial);
    scene.add(particlesMesh);

    // 保留旧的第 1 个トーラス
    const torusGeometry = new THREE.TorusGeometry(10, 3, 16, 100);
    const torusMaterial = new THREE.MeshBasicMaterial({
      color: 0xa855f7,
      wireframe: true,
      transparent: true,
      opacity: 0.3,
    });
    torus = new THREE.Mesh(torusGeometry, torusMaterial);
    scene.add(torus);

    // 保留旧的第 2 つ目のトーラス
    const torus2Geometry = new THREE.TorusGeometry(15, 2, 16, 100);
    const torus2Material = new THREE.MeshBasicMaterial({
      color: 0xec4899,
      wireframe: true,
      transparent: true,
      opacity: 0.2,
    });
    torus2 = new THREE.Mesh(torus2Geometry, torus2Material);
    torus2.rotation.x = Math.PI / 4;
    scene.add(torus2);

    // ==========================================
    // 新增：类似土星的小行星带星环 (Saturn Asteroid Ring)
    // ==========================================
    const ringParticlesCount = 3200;
    const ringGeometry = new THREE.BufferGeometry();
    const ringPos = new Float32Array(ringParticlesCount * 3);
    const ringColors = new Float32Array(ringParticlesCount * 3);

    for (let i = 0; i < ringParticlesCount; i++) {
      const idx = i * 3;
      // 环盘内径 7.5，外径 13.5
      const r = 7.5 + Math.random() * 6.0;
      const theta = Math.random() * Math.PI * 2;
      const z = (Math.random() - 0.5) * 0.35; // 纤薄盘面

      ringPos[idx] = r * Math.cos(theta);
      ringPos[idx + 1] = r * Math.sin(theta);
      ringPos[idx + 2] = z;

      // 小行星光点色彩（亮彩、粉紫、星光白）
      const rand = Math.random();
      if (rand < 0.45) {
        ringColors[idx] = 0.66; ringColors[idx + 1] = 0.33; ringColors[idx + 2] = 0.97;
      } else if (rand < 0.75) {
        ringColors[idx] = 0.96; ringColors[idx + 1] = 0.96; ringColors[idx + 2] = 1.0;
      } else {
        ringColors[idx] = 0.93; ringColors[idx + 1] = 0.28; ringColors[idx + 2] = 0.60;
      }
    }

    ringGeometry.setAttribute('position', new THREE.BufferAttribute(ringPos, 3));
    ringGeometry.setAttribute('color', new THREE.BufferAttribute(ringColors, 3));

    const ringMaterial = new THREE.PointsMaterial({
      size: 0.18,
      map: circleTexture,
      vertexColors: true,
      transparent: true,
      opacity: 0.75,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
    });

    asteroidRing = new THREE.Points(ringGeometry, ringMaterial);
    asteroidRing.rotation.x = Math.PI / 3;
    asteroidRing.rotation.y = Math.PI / 8;
    scene.add(asteroidRing);

    // イベントリスナーの追加
    document.addEventListener('mousemove', handleMouseMove);
    window.addEventListener('resize', handleResize);

    // アニメーションループの開始
    time = 0;
    animate();
  }

  // アニメーションループ
  function animate() {
    if (!scene || !camera || !renderer || !particlesMesh || !torus || !torus2) return;

    animationId = requestAnimationFrame(animate);
    time += 0.001;

    // パーティクルの回転とうねり
    particlesMesh.rotation.y = time * 0.15;
    particlesMesh.rotation.x = Math.sin(time * 0.5) * 0.08;

    // トーラスの回転（恢复旧旋转逻辑）
    torus.rotation.x += 0.01;
    torus.rotation.y += 0.005;
    torus.rotation.z += 0.003;

    torus2.rotation.x += 0.005;
    torus2.rotation.y += 0.01;
    torus2.rotation.z += 0.002;

    // 土星小行星环动态沿轨道旋转
    if (asteroidRing) {
      asteroidRing.rotation.z += 0.0018;
    }

    // マウス追従
    camera.position.x = mouseX * 2;
    camera.position.y = mouseY * 2;
    camera.lookAt(scene.position);

    renderer.render(scene, camera);
  }

  // クリーンアップ
  function cleanupThreeAnimation() {
    // アニメーションループの停止
    if (animationId !== null) {
      cancelAnimationFrame(animationId);
      animationId = null;
    }

    // イベントリスナーの削除
    document.removeEventListener('mousemove', handleMouseMove);
    window.removeEventListener('resize', handleResize);

    // Three.jsオブジェクトのクリーンアップ
    if (particlesMesh) {
      particlesMesh.geometry.dispose();
      if (particlesMesh.material.map) {
        particlesMesh.material.map.dispose();
      }
      particlesMesh.material.dispose();
      particlesMesh = null;
    }

    if (torus) {
      torus.geometry.dispose();
      torus.material.dispose();
      torus = null;
    }

    if (torus2) {
      torus2.geometry.dispose();
      torus2.material.dispose();
      torus2 = null;
    }

    if (asteroidRing) {
      asteroidRing.geometry.dispose();
      if (asteroidRing.material.map) {
        asteroidRing.material.map.dispose();
      }
      asteroidRing.material.dispose();
      asteroidRing = null;
    }

    if (renderer) {
      renderer.dispose();
      renderer = null;
    }

    scene = null;
    camera = null;
  }

  // Astro View Transitionsに対応した初期化
  document.addEventListener('astro:page-load', () => {
    initThreeAnimation();
  });

  // ページ離脱時のクリーンアップ
  document.addEventListener('astro:before-preparation', () => {
    cleanupThreeAnimation();
  });
</script>

<style>
  #three-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }
</style>
