---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About - FrankWkd's Studio" description="About FrankWkd, Skills, Projects & Contacts">
  <Navigation />

  <main class="about-page">
    <div class="container">
      
      <!-- Studio Header -->
      <header class="studio-header">
        <h1 class="studio-title">FrankWkd's Studio</h1>
        <p class="studio-slogan">&gt; Love loves to love love.</p>
      </header>

      <!-- Tip Alert Box -->
      <div class="tip-alert">
        <div class="tip-icon">📔</div>
        <div class="tip-content">
          <strong>写在前面：</strong> 请有话直说、一定要及时沟通 🤍（本人可 i 可 e）
        </div>
      </div>

      <!-- About Me Section -->
      <section class="section-card">
        <h2 class="section-heading">
          <span class="icon">🤔</span> About Me
        </h2>
        <div class="tags-container">
          <span class="tag tag-purple">独立开发者</span>
          <span class="tag tag-pink">ENFJ 主人公</span>
          <span class="tag tag-blue">摄影发烧友</span>
          <span class="tag tag-cyan">爱玩 & 啥都想知道</span>
        </div>
        <div class="about-grid">
          <div class="info-box">
            <h3>💡 个人态度</h3>
            <p>喜欢创造开发，一直折腾。关注科技热点，任何天马行空或特定技术话题都🉑聊！</p>
          </div>
          <div class="info-box">
            <h3>⚙️ Working on</h3>
            <p><strong>Web 独立开发</strong> || <strong>桌面应用开发</strong></p>
          </div>
        </div>
      </section>

      <!-- My Skills Section -->
      <section class="section-card">
        <h2 class="section-heading">
          <span class="icon">⚙️</span> My Skills
        </h2>
        <div class="skills-summary-grid">
          <div class="skill-summary-card">
            <h4>💻 技术</h4>
            <p>软件和 Web 都擅长，基本不玩硬件 🫠</p>
          </div>
          <div class="skill-summary-card">
            <h4>🎨 美工 & 摄影</h4>
            <p>擅长 PPT、前端勉强会 || 擅长剪辑 & 摄影</p>
          </div>
          <div class="skill-summary-card">
            <h4>📝 文字</h4>
            <p>基本所有类型都 🉑，可接稿件文件数据表，学习吸收能力很强</p>
          </div>
          <div class="skill-summary-card">
            <h4>🗣️ 表达 (ENFJ 舒适区)</h4>
            <p>可演讲 (有 TEDx 经验)，可协调组织，可讲故事，可随机应变 / 即兴讲演</p>
          </div>
        </div>

        <!-- Skills Badges Table / Grid -->
        <div class="skills-matrix">
          <div class="matrix-row">
            <div class="matrix-label">System</div>
            <div class="matrix-badges">
              <img src="https://img.shields.io/badge/-Linux-FCC624?style=flat-square&logo=linux&logoColor=black" alt="Linux" />
              <img src="https://img.shields.io/badge/-Arch%20Linux-1793D1?style=flat-square&logo=arch-linux&logoColor=white" alt="Arch Linux" />
            </div>
          </div>
          <div class="matrix-row">
            <div class="matrix-label">Languages</div>
            <div class="matrix-badges">
              <img src="https://img.shields.io/badge/-C%2B%2B-00599C?style=flat-square&logo=c%2B%2B&logoColor=white" alt="C++" />
              <img src="https://img.shields.io/badge/-Python-3776AB?style=flat-square&logo=python&logoColor=white" alt="Python" />
              <img src="https://img.shields.io/badge/-Rust-000000?style=flat-square&logo=rust&logoColor=white" alt="Rust" />
              <img src="https://img.shields.io/badge/-Node.js-339933?style=flat-square&logo=node.js&logoColor=white" alt="Node.js" />
              <img src="https://img.shields.io/badge/-JavaScript-F7DF1E?style=flat-square&logo=javascript&logoColor=black" alt="JavaScript" />
            </div>
          </div>
          <div class="matrix-row">
            <div class="matrix-label">Tools</div>
            <div class="matrix-badges">
              <img src="https://img.shields.io/badge/-Vim-019733?style=flat-square&logo=vim&logoColor=white" alt="Vim" />
              <img src="https://img.shields.io/badge/-VS%20Code-007ACC?style=flat-square&logo=visual-studio-code&logoColor=white" alt="VS Code" />
              <img src="https://img.shields.io/badge/-Docker-2496ED?style=flat-square&logo=docker&logoColor=white" alt="Docker" />
              <img src="https://img.shields.io/badge/-GitHub-181717?style=flat-square&logo=github&logoColor=white" alt="GitHub" />
              <img src="https://img.shields.io/badge/-Git-F05032?style=flat-square&logo=git&logoColor=white" alt="Git" />
              <img src="https://img.shields.io/badge/-Cloudflare-F38020?style=flat-square&logo=cloudflare&logoColor=white" alt="Cloudflare" />
              <img src="https://img.shields.io/badge/-Obsidian-483699?style=flat-square&logo=obsidian&logoColor=white" alt="Obsidian" />
            </div>
          </div>
          <div class="matrix-row">
            <div class="matrix-label">AI</div>
            <div class="matrix-badges">
              <img src="https://img.shields.io/badge/-Gemini-8E75FF?style=flat-square&logo=googlegemini&logoColor=white" alt="Gemini" />
              <img src="https://img.shields.io/badge/-Claude-D97757?style=flat-square&logo=claude&logoColor=white" alt="Claude" />
              <img src="https://img.shields.io/badge/Perplexity-20B2AA?style=flat-square&logo=perplexity&logoColor=white" alt="Perplexity" />
            </div>
          </div>
          <div class="matrix-row">
            <div class="matrix-label">OI</div>
            <div class="matrix-badges">
              <img src="https://img.shields.io/badge/-Luogu-3498DB?style=flat-square&logo=codeforces&logoColor=white" alt="Luogu" />
              <img src="https://img.shields.io/badge/-LeetCode-F7F7F7?style=flat-square&logo=leetcode&logoColor=black" alt="LeetCode" />
              <img src="https://img.shields.io/badge/-Codeforces-445f9d?style=flat-square&logo=codeforces&logoColor=white" alt="Codeforces" />
            </div>
          </div>
        </div>
      </section>

      <!-- Stack & Experience Section -->
      <section class="section-card">
        <h2 class="section-heading">
          <span class="icon">🛠️</span> Stack & Experience
        </h2>
        <div class="projects-grid">
          <a href="https://github.com/FrankWkd-Plus/Tarot-Game" target="_blank" class="project-card">
            <div class="project-header">
              <span class="project-icon">🔮</span>
              <h3>在线塔罗牌占卜</h3>
            </div>
            <p>在线获取关于困扰你问题的塔罗牌占卜，支持 AI 深入深度分析。</p>
            <span class="demo-link">Demo 🔗</span>
          </a>

          <a href="https://github.com/FrankWkd-Plus/2026-Tcamp-Mini-Program-Competition" target="_blank" class="project-card">
            <div class="project-header">
              <span class="project-icon">⚙️</span>
              <h3>2026 Tcamp 微信小程序</h3>
            </div>
            <p>微信小程序 AI 创新挑战赛参赛作品项目源码。</p>
          </a>

          <a href="https://ai-work-team-demo.pages.dev/AI_Group_Chat_Pro_Beta%E6%9C%80%E7%BB%88" target="_blank" class="project-card">
            <div class="project-header">
              <span class="project-icon">🤖</span>
              <h3>AI Workstation</h3>
            </div>
            <p>将多渠道 AI 进行聚合并协同合作进行高效协同开发。</p>
          </a>

          <a href="https://blog.frankwkd2026.dpdns.org" target="_blank" class="project-card">
            <div class="project-header">
              <span class="project-icon">📜</span>
              <h3>Personal Blog</h3>
            </div>
            <p>基于 Quartz 4 框架精心打造的独立极客个人博客。</p>
          </a>

          <a href="https://frankwkd2026.dpdns.org" target="_blank" class="project-card">
            <div class="project-header">
              <span class="project-icon">📝</span>
              <h3>Domain Mail System</h3>
            </div>
            <p>基于开源项目二次开发的独立域名邮局系统。</p>
          </a>

          <a href="https://paste.frankwkd2026.dpdns.org" target="_blank" class="project-card">
            <div class="project-header">
              <span class="project-icon">✂️</span>
              <h3>Encrypted Pastebin</h3>
            </div>
            <p>支持极简加密的 Markdown 代码剪贴板与长文分享。</p>
          </a>

          <a href="https://u.frankwkd2026.dpdns.org" target="_blank" class="project-card">
            <div class="project-header">
              <span class="project-icon">👉</span>
              <h3>Url Shorten</h3>
            </div>
            <p>高效、轻量级的短链接生成器服务。</p>
          </a>

          <a href="https://proxy.frankwkd2026.dpdns.org/" target="_blank" class="project-card">
            <div class="project-header">
              <span class="project-icon">🛡️</span>
              <h3>Website Proxy</h3>
            </div>
            <p>使用 Cloudflare Workers 实现的高性能网站反向代理。</p>
          </a>

          <a href="https://gh-agent.frankwkd2026.dpdns.org/" target="_blank" class="project-card">
            <div class="project-header">
              <span class="project-icon">📊</span>
              <h3>Github Download Agent</h3>
            </div>
            <p>Github Releases / 源码文件下载 CDN 镜像加速代理。</p>
          </a>

          <a href="https://sub.frankwkd2026.dpdns.org/" target="_blank" class="project-card">
            <div class="project-header">
              <span class="project-icon">🕸️</span>
              <h3>CF Edge Node Generator</h3>
            </div>
            <p>利用 Cloudflare 边缘节点代理流量并智能生成订阅节点。</p>
          </a>

          <div class="project-card simple">
            <div class="project-header">
              <span class="project-icon">💡</span>
              <h3>Progress Tracker</h3>
            </div>
            <p>托管在微信开发者平台的任务追踪进度管理软件。</p>
          </div>

          <a href="https://status.frankwkd2026.dpdns.org" target="_blank" class="project-card">
            <div class="project-header">
              <span class="project-icon">👀</span>
              <h3>云服务器探针</h3>
            </div>
            <p>利用 Beszel 框架搭建的探针&资源监控，结合 Cloudflared Tunnel 进行端口安全转发。</p>
          </a>
        </div>

        <!-- Deprecated Projects Box -->
        <div class="deprecated-box">
          <h4 class="deprecated-title">⛔ 停止维护项目</h4>
          <ul class="deprecated-list">
            <li><strong>CDK Management System</strong> — 基于 Cloudflare Worker 的卡密分发系统。</li>
            <li><strong>Telegram Gemini Bot</strong> — 基于 Gemini API 自动化响应的 Telegram AI 机器人。</li>
            <li><strong>Sublink Pro</strong> — 基于开源二次开发的订阅管理&节点分发系统，由 GCP 托管。</li>
          </ul>
        </div>

        <!-- Protection Warning Alert -->
        <div class="protection-alert">
          <span class="shield-icon">🛡️</span>
          <span>已经全域部署 <strong>Cloudflare Turnstile</strong> 攻击防护！</span>
        </div>
      </section>

      <!-- Find Me Section -->
      <section class="section-card contact-section">
        <h2 class="section-heading">
          <span class="icon">🔎</span> Find Me Here
        </h2>
        <p class="contact-intro">保持沟通！欢迎通过以下方式找到我 👀：</p>
        
        <div class="contacts-grid">
          <a href="mailto:master@frankwkd2026.dpdns.org" class="contact-card">
            <span class="contact-icon">📧</span>
            <div class="contact-info">
              <span class="contact-label">Email</span>
              <span class="contact-val">master@frankwkd2026.dpdns.org</span>
            </div>
          </a>

          <a href="https://github.com/FrankWkd-Plus" target="_blank" class="contact-card">
            <span class="contact-icon">🐙</span>
            <div class="contact-info">
              <span class="contact-label">GitHub</span>
              <span class="contact-val">FrankWkd-Plus</span>
            </div>
          </a>

          <a href="https://t.me/frankwkd_pro" target="_blank" class="contact-card">
            <span class="contact-icon">✈️</span>
            <div class="contact-info">
              <span class="contact-label">Telegram</span>
              <span class="contact-val">@frankwkd_pro</span>
            </div>
          </a>

          <a href="https://www.nodeloc.com/u/FlankW/" target="_blank" class="contact-card">
            <span class="contact-icon">🌐</span>
            <div class="contact-info">
              <span class="contact-label">Nodeloc</span>
              <span class="contact-val">FlankW</span>
            </div>
          </a>

          <a href="https://codeforces.com/profile/FrankWkd" target="_blank" class="contact-card">
            <span class="contact-icon">🏆</span>
            <div class="contact-info">
              <span class="contact-label">CodeForces</span>
              <span class="contact-val">FrankWkd</span>
            </div>
          </a>

          <a href="https://www.xiaohongshu.com/user/profile/63c93481000000002702a73f" target="_blank" rel="noopener noreferrer" class="contact-card">
            <span class="contact-icon">📕</span>
            <div class="contact-info">
              <span class="contact-label">小红书</span>
              <span class="contact-val">mrfrankwkd</span>
            </div>
          </a>
        </div>
      </section>

    </div>
  </main>
</BaseLayout>

<style>
  .about-page {
    min-height: 100vh;
    padding: calc(var(--nav-height) + 1.5rem) 1.5rem 5rem;
    overflow-y: auto;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Header Styles */
  .studio-header {
    text-align: center;
    padding: 1.5rem 0 0.5rem;
  }

  .studio-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    background: linear-gradient(135deg, #3B82F6 0%, #93C5FD 50%, #A855F7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 15px rgba(59, 130, 246, 0.35));
    margin-bottom: 0.5rem;
  }

  .studio-slogan {
    font-family: 'Fira Code', monospace, sans-serif;
    font-size: 1.1rem;
    color: var(--color-text-dim);
    letter-spacing: 0.05em;
  }

  /* Tip Alert */
  .tip-alert {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 1rem;
    backdrop-filter: blur(8px);
  }

  .tip-icon {
    font-size: 1.5rem;
  }

  .tip-content {
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.5;
  }

  /* Section Cards */
  .section-card {
    background: rgba(30, 41, 59, 0.7);
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    padding: 2rem;
    backdrop-filter: blur(12px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    transition: border-color 0.3s ease;
  }

  .section-card:hover {
    border-color: rgba(59, 130, 246, 0.4);
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Tags */
  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    font-size: 0.9rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
  }

  .tag-purple { background: rgba(168, 85, 247, 0.15); color: #C084FC; border-color: rgba(168, 85, 247, 0.3); }
  .tag-pink { background: rgba(236, 72, 153, 0.15); color: #F472B6; border-color: rgba(236, 72, 153, 0.3); }
  .tag-blue { background: rgba(59, 130, 246, 0.15); color: #60A5FA; border-color: rgba(59, 130, 246, 0.3); }
  .tag-cyan { background: rgba(6, 182, 212, 0.15); color: #22D3EE; border-color: rgba(6, 182, 212, 0.3); }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .info-box {
    padding: 1.25rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--color-border);
    border-radius: 0.875rem;
  }

  .info-box h3 {
    font-size: 1.1rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .info-box p {
    color: var(--color-text-dim);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* Skills Summary Grid */
  .skills-summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .skill-summary-card {
    padding: 1.25rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--color-border);
    border-radius: 0.875rem;
  }

  .skill-summary-card h4 {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .skill-summary-card p {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    line-height: 1.5;
  }

  /* Skills Matrix */
  .skills-matrix {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: rgba(15, 23, 42, 0.8);
    padding: 1.5rem;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
  }

  .matrix-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .matrix-label {
    min-width: 100px;
    font-weight: 700;
    color: var(--color-primary);
    font-family: var(--font-heading);
  }

  .matrix-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .matrix-badges img {
    height: 24px;
    border-radius: 4px;
  }

  /* Projects Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.25rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--color-border);
    border-radius: 0.875rem;
    text-decoration: none;
    transition: all 0.25 ease;
  }

  .project-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-primary);
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.2);
  }

  .project-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-icon {
    font-size: 1.25rem;
  }

  .project-card h3 {
    font-size: 1.05rem;
    color: var(--color-text);
    font-weight: 600;
  }

  .project-card p {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .demo-link {
    font-size: 0.8rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .project-card.simple {
    cursor: default;
  }

  /* Deprecated Box */
  .deprecated-box {
    background: rgba(239, 68, 68, 0.05);
    border: 1px dashed rgba(239, 68, 68, 0.3);
    border-radius: 0.875rem;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .deprecated-title {
    color: #F87171;
    margin-bottom: 0.75rem;
    font-size: 1rem;
  }

  .deprecated-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .deprecated-list li {
    font-size: 0.9rem;
    color: var(--color-text-dim);
  }

  .deprecated-list strong {
    color: var(--color-text);
  }

  /* Protection Alert */
  .protection-alert {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: rgba(234, 179, 8, 0.1);
    border: 1px solid rgba(234, 179, 8, 0.3);
    border-radius: 0.75rem;
    color: #FACC15;
    font-size: 0.95rem;
  }

  /* Contact Section */
  .contact-intro {
    color: var(--color-text-dim);
    margin-bottom: 1.5rem;
  }

  .contacts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--color-border);
    border-radius: 0.875rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .contact-card:hover:not(.no-link) {
    border-color: var(--color-primary);
    transform: translateY(-2px);
